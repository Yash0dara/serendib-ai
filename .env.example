# .env.example
# Copy this file and rename it to .env
# Fill in your actual values

# ================================
# APP SETTINGS
# ================================
APP_NAME=Serendib AI
DEBUG=True

# ================================
# LLM - GROQ (Free)
# Get your key at: console.groq.com
# ================================
GROQ_API_KEY=your_groq_api_key_here

# ================================
# WEATHER API (Free)
# Get your key at: openweathermap.org
# ================================
OPENWEATHER_API_KEY=your_openweather_key_here

# ================================
# DATABASE - MONGODB (Free)
# Get connection string at: mongodb.com/atlas
# ================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/serendib_ai

# ================================
# REDIS CACHE (Optional - Skip for now)
# Get connection at: upstash.com
# ================================
REDIS_URL=redis://default:password@host:6379